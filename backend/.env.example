# SpendHound Backend Environment Variables
# Copy this to .env and fill in your values.

DATABASE_URL=postgresql+asyncpg://spendhound:localdev@db:5432/spendhound

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=7

LLM_PROVIDER=ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
NEBIUS_API_KEY=
NEBIUS_MODEL=
NEBIUS_BASE_URL=

# Approval workflow / admin notifications
# - ADMIN_EMAIL must be the inbox that should receive approval requests.
# - APP_URL must be the public frontend URL used in approve/reject links.
#   Use http://localhost:3001 for Docker Compose, or http://localhost:3000 for local frontend dev.
# - RESEND_API_KEY is required for approval emails to be sent.
# - RESEND_FROM_EMAIL should be a Resend-valid sender for your account/domain.
ADMIN_EMAIL=srsudhir31@gmail.com
APP_URL=http://localhost:3000
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Monthly reports
# - Enable the job only after the internal frontend PDF endpoint is available.
# - MONTHLY_REPORTS_FRONTEND_PDF_URL should be reachable from the backend container, for example
#   http://frontend:3000/api/internal/reports/monthly-pdf
# - The backend will POST a JSON body containing user_id, user_email, user_name, and report_month (YYYY-MM)
#   and expects raw PDF bytes in the response.
MONTHLY_REPORTS_ENABLED=false
MONTHLY_REPORTS_TIMEZONE=UTC
MONTHLY_REPORTS_FRONTEND_PDF_URL=
MONTHLY_REPORTS_FRONTEND_TOKEN=
MONTHLY_REPORTS_FRONTEND_TOKEN_HEADER=X-SpendHound-Internal-Token
MONTHLY_REPORTS_FRONTEND_TIMEOUT_SECONDS=60

DEBUG=false
DEFAULT_CURRENCY=EUR
RECEIPT_STORAGE_DIR=storage/receipts
RECEIPT_REVIEW_CONFIDENCE_THRESHOLD=0.75
RECEIPT_MULTIMODAL_MAX_BYTES=7500000
