# SpendHound Frontend Environment Variables
# Copy this to .env.local for local development or to .env for Docker Compose.

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
