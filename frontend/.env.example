# SpendHound Frontend Environment Variables
# Copy this to .env.local for local development or to .env for Docker Compose.

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional for non-Docker runs:
# NEXT_PUBLIC_API_URL=http://localhost:8000
# INTERNAL_API_URL=http://localhost:8000

# Shared-secret auth for the internal monthly PDF endpoint consumed by the backend job.
MONTHLY_REPORTS_FRONTEND_TOKEN=
MONTHLY_REPORTS_FRONTEND_TOKEN_HEADER=X-SpendHound-Internal-Token

# Narrow bridge for server-side per-user analytics loading without backend changes.
# Set this to the same JWT secret used by the backend so the frontend can mint a
# short-lived internal bearer token for the requested user when calling
# /api/analytics/dashboard.
MONTHLY_REPORTS_BACKEND_JWT_SECRET=
MONTHLY_REPORTS_BACKEND_JWT_ALGORITHM=HS256

# Optional override when Chromium is installed in a non-standard location.
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
