{
  "title": "SpendHound",
  "uid": "spendhound-main",
  "description": "SpendHound observability — request latency, receipt queue, LLM timing, rate limits",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["spendhound"],
  "editable": true,
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Latency p95 (by route)",
      "description": "95th-percentile response time across all FastAPI routes. Uses the high-resolution histogram from prometheus-fastapi-instrumentator.",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, handler) (rate(http_request_duration_highr_seconds_bucket[5m])))",
          "legendFormat": "p95 {{handler}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (le, handler) (rate(http_request_duration_highr_seconds_bucket[5m])))",
          "legendFormat": "p50 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Receipt Queue Depth",
      "description": "Number of receipt/statement extraction tasks waiting in the Celery/Redis queue. Sampled on every /metrics scrape (15 s).",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "receipt_queue_depth",
          "legendFormat": "queue depth"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 9 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "LLM Response Time by Provider",
      "description": "complete() call latency histogram, labelled by provider (ollama/openai/anthropic/etc.).",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, provider) (rate(llm_response_seconds_bucket[5m])))",
          "legendFormat": "p95 {{provider}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (le, provider) (rate(llm_response_seconds_bucket[5m])))",
          "legendFormat": "p50 {{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Rate Limit Hits",
      "description": "Rate of requests rejected by slowapi, labelled by endpoint and limit_type (upload / chat / auth / other).",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (limit_type) (rate(rate_limit_hits_total[5m]))",
          "legendFormat": "{{limit_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    }
  ]
}
